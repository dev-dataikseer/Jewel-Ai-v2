# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# Next.js Build Cache
frontend/.next/
frontend/.next-env.d.ts

# Production Build Output (Optional to commit, but excluded by default. Since you copy/stage pre-compiled builds, let's allow it in frontend/out but ignore general logs)
crash.log
backend/logs/*.log

# Local databases
backend/prisma/*.db
backend/prisma/*.db-journal
backend/prisma/*.db-shm
backend/prisma/*.db-wal

# Dynamic assets / uploads
backend/uploads/*
!backend/uploads/.gitkeep

# Environment variables
.env
.env.local
.env.production
.env.development
.env.staging
backend/.env
frontend/.env.local

# OS Files
.DS_Store
Thumbs.db

# Large zips and deploy bundles
*.zip
*.rar
production_temp/
